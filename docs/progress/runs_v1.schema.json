{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omniscripta.local/schemas/progress/runs_v1.schema.json",
  "title": "Progress Run Record v1",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "job_id",
    "content_hash_sha256",
    "ts_start_utc",
    "ts_end_utc",
    "host_id",
    "worker_instance",
    "snippet_seconds",
    "topics_enabled",
    "chunks_count",
    "config_key",
    "hardware_key",
    "phase_seconds",
    "wait_seconds",
    "total_seconds",
    "outcome",
    "error_text"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "job_id": { "type": "string", "minLength": 1 },
    "content_hash_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "ts_start_utc": { "type": "string", "minLength": 1 },
    "ts_end_utc": { "type": "string", "minLength": 1 },
    "host_id": { "type": "string", "minLength": 1 },
    "worker_instance": { "type": "string", "minLength": 1 },
    "snippet_seconds": { "type": "number", "minimum": 0 },
    "topics_enabled": { "type": "boolean" },
    "speaker_mode": { "type": "string", "enum": ["none", "auto", "fixed"] },
    "chunks_count": { "type": "integer", "minimum": 0 },
    "config_key": { "type": "string", "minLength": 1 },
    "hardware_key": { "type": "string", "minLength": 1 },
    "phase_seconds": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0 }
    },
    "wait_seconds": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0 }
    },
    "total_seconds": { "type": "number", "minimum": 0 },
    "outcome": { "enum": ["done", "error"] },
    "error_text": { "type": "string" }
  },
  "additionalProperties": false
}
